# Backend environment variables
# Copy to `backend/.env` (or set in your host) and never commit real secrets to git.

# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://neondb_owner:npg_Yk68iIhSfpBt@ep-icy-sound-a10qt4gm-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
JWT_SECRET=your_secret

# Auth
JWT_SECRET=replace_with_strong_secret

# AWS S3 (must match keys used in backend/src/config/env.js)
