AWS_ACCESS_KEY=your_access_key
AWS_SECRET_KEY=your_secret_key
AWS_BUCKET_NAME=ebook-eshiksha
AWS_S3_ENDPOINT=

# CORS origins allowed by backend (comma-separated, no trailing slash preferred)
# Example: http://localhost:3000,https://eshiksha-khaki.vercel.app
FRONTEND_ORIGIN=http://localhost:3000

# Razorpay
